---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}
const { article } = Astro.props;
const { data } = article;
const dateText = data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={data.title} description={data.summary}>
  <article class="article">
    <header class="head measure">
      <p class="eyebrow">
        {data.topics.join(' · ') || 'Notes'}
        {data.readingTime && <span> · {data.readingTime}</span>}
      </p>
      <h1>{data.title}</h1>
      {data.subtitle && <p class="subtitle">{data.subtitle}</p>}
      <p class="byline">{dateText}</p>
    </header>

    {data.cover && (
      <figure class="cover wrap">
        <img src={data.cover} alt={data.title} loading="eager" />
      </figure>
    )}

    <div class="prose measure">
      <slot />
    </div>

    <p class="back measure">
      <a href="/science/">← All writing</a>
    </p>
  </article>
</BaseLayout>

<style>
  .article { padding-top: clamp(2rem, 7vw, 5rem); }
  .head { text-align: center; margin-bottom: clamp(2rem, 6vw, 3.5rem); }
  .subtitle {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1rem + 0.6vw, 1.5rem);
    color: var(--muted);
    margin: 0.4rem 0 1rem;
  }
  .byline {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .cover {
    margin: 0 auto clamp(2rem, 6vw, 4rem);
  }
  .cover img { width: 100%; border-radius: var(--radius); }

  /* Prose typography for long-form science writing. */
  .prose { font-size: 1.075rem; }
  .prose :global(h2) { margin-top: 2.2em; }
  .prose :global(h3) { margin-top: 1.6em; }
  .prose :global(img) {
    border-radius: var(--radius);
    margin-block: 1.5rem;
  }
  .prose :global(figure) { margin-inline: 0; }
  .prose :global(figcaption) {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--muted);
    text-align: center;
    margin-top: 0.5rem;
  }
  .prose :global(blockquote) {
    margin: 1.5rem 0;
    padding-left: 1.2rem;
    border-left: 2px solid var(--accent);
    font-family: var(--font-display);
    font-style: italic;
    color: var(--muted);
  }
  .prose :global(pre) {
    padding: 1.1rem 1.25rem;
    border-radius: var(--radius);
    overflow-x: auto;
    border: 1px solid var(--line);
    font-size: 0.9rem;
  }
  .prose :global(code) { font-family: var(--font-mono); font-size: 0.92em; }
  .prose :global(:not(pre) > code) {
    background: color-mix(in oklab, var(--ink) 7%, transparent);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 2.5rem 0;
  }
  /* KaTeX display blocks shouldn't overflow on mobile. */
  .prose :global(.katex-display) { overflow-x: auto; overflow-y: hidden; padding-block: 0.4rem; }

  .back {
    margin-top: clamp(2.5rem, 7vw, 4rem);
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  .back a { color: var(--muted); }
  .back a:hover { color: var(--accent); }
</style>
