---
interface Img {
  src: string;
  alt: string;
  caption?: string;
  span?: 'single' | 'wide';
}
interface Props {
  images: Img[];
}
const { images } = Astro.props;
---

<div class="grid">
  {images.map((img, i) => (
    <figure class:list={['cell', { wide: img.span === 'wide' }]} data-reveal={String(i % 6)}>
      <button class="open" data-full={img.src} data-cap={img.caption ?? img.alt} aria-label={`View ${img.alt}`}>
        <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
      </button>
      {img.caption && <figcaption>{img.caption}</figcaption>}
    </figure>
  ))}
</div>

<!-- Lightbox -->
<dialog class="lightbox" data-lightbox>
  <button class="close" aria-label="Close" data-close>&times;</button>
  <figure>
    <img alt="" data-lightbox-img />
    <figcaption data-lightbox-cap></figcaption>
  </figure>
</dialog>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: var(--gap);
    align-items: start;
  }
  .cell { margin: 0; }
  .cell.wide { grid-column: 1 / -1; }
  .open {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: color-mix(in oklab, var(--ink) 6%, transparent);
    cursor: zoom-in;
    overflow: hidden;
    border-radius: var(--radius);
  }
  .open img {
    width: 100%;
    transition: transform 0.9s var(--ease), filter 0.6s var(--ease);
  }
  .open:hover img { transform: scale(1.03); }
  figcaption {
    margin-top: 0.55rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--muted);
  }

  .lightbox {
    border: 0;
    padding: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    margin: 0;
    overflow: hidden;
  }
  .lightbox::backdrop {
    background: color-mix(in oklab, #000 88%, transparent);
    backdrop-filter: blur(6px);
  }
  .lightbox figure {
    margin: 0;
    height: 100%;
    display: grid;
    place-content: center;
    gap: 0.75rem;
    padding: clamp(1rem, 5vw, 3rem);
  }
  .lightbox img {
    max-width: min(92vw, 1400px);
    max-height: 82vh;
    width: auto;
    border-radius: var(--radius);
  }
  .lightbox figcaption {
    text-align: center;
    color: rgba(255, 255, 255, 0.8);
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  .close {
    position: fixed;
    top: 1rem;
    right: 1.25rem;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(0, 0, 0, 0.3);
    color: #fff;
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
  }
</style>

<script>
  const dialog = document.querySelector('[data-lightbox]') as HTMLDialogElement | null;
  if (dialog) {
    const img = dialog.querySelector('[data-lightbox-img]') as HTMLImageElement;
    const cap = dialog.querySelector('[data-lightbox-cap]') as HTMLElement;
    document.querySelectorAll('.open').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        img.src = el.dataset.full || '';
        img.alt = el.dataset.cap || '';
        cap.textContent = el.dataset.cap || '';
        dialog.showModal();
      });
    });
    const close = () => dialog.close();
    dialog.querySelector('[data-close]')?.addEventListener('click', close);
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) close();
    });
  }
</script>
