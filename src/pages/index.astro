---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const published = (c: { data: { draft: boolean } }) => import.meta.env.DEV || !c.data.draft;

const galleries = (await getCollection('galleries', published)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const articles = (await getCollection('articles', published)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featuredGallery = galleries.find((g) => g.data.featured) ?? galleries[0];
const latestArticle = articles[0];

// Sections of the studio — the ones that aren't live yet are marked "soon".
const sections = [
  { href: '/photography/', label: 'Photography', note: 'Galleries, each its own world', ready: true },
  { href: '/science/', label: 'Science', note: 'Notes on hydroponics, optics & more', ready: true },
  { href: '#', label: 'Video', note: 'Coming soon', ready: false },
  { href: '#', label: 'Poetry', note: 'Coming soon', ready: false },
  { href: '#', label: 'Travel', note: 'Coming soon', ready: false },
];
---

<BaseLayout title="Marc-André Vigneault">
  <section class="hero wrap">
    <p class="eyebrow" data-reveal>Photographer · Scientist · Maker</p>
    <h1 data-reveal="1">A studio for<br />things I love to make.</h1>
    <p class="lede" data-reveal="2">
      Photography, scientific writing, travel and poetry — each gathered here in its own
      light. Wander in.
    </p>
  </section>

  <nav class="sections wrap" aria-label="Sections">
    {sections.map((s, i) => (
      <a
        href={s.href}
        class:list={['section-card', { soon: !s.ready }]}
        data-reveal={String(i)}
        aria-disabled={!s.ready}
      >
        <span class="label">{s.label}</span>
        <span class="note">{s.note}</span>
      </a>
    ))}
  </nav>

  {featuredGallery && (
    <section class="feature wrap" data-reveal>
      <a href={`/photography/${featuredGallery.id}/`} class="feature-link" style={`--cover:url('${featuredGallery.data.cover}')`}>
        <div class="feature-bg"></div>
        <div class="feature-text">
          <p class="eyebrow">Featured gallery</p>
          <h2>{featuredGallery.data.title}</h2>
          <p>{featuredGallery.data.summary}</p>
          <span class="cta">Enter the gallery →</span>
        </div>
      </a>
    </section>
  )}

  {latestArticle && (
    <section class="latest measure" data-reveal>
      <p class="eyebrow">Latest writing</p>
      <a href={`/science/${latestArticle.id}/`} class="latest-link">
        <h3>{latestArticle.data.title}</h3>
        <p>{latestArticle.data.summary}</p>
        <span class="cta">Read →</span>
      </a>
    </section>
  )}
</BaseLayout>

<style>
  .hero { padding-block: clamp(4rem, 14vw, 9rem) clamp(2rem, 6vw, 4rem); }
  .hero h1 { max-width: 16ch; }
  .lede {
    max-width: 50ch;
    font-size: clamp(1.1rem, 1rem + 0.6vw, 1.4rem);
    color: var(--muted);
  }

  .sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: clamp(3rem, 9vw, 6rem);
  }
  .section-card {
    background: var(--paper);
    padding: clamp(1.3rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-height: 120px;
    justify-content: flex-end;
    transition: background-color 0.4s var(--ease);
  }
  .section-card:hover { background: color-mix(in oklab, var(--accent) 8%, var(--paper)); }
  .section-card .label { font-family: var(--font-display); font-size: 1.35rem; }
  .section-card .note { font-size: 0.82rem; color: var(--muted); }
  .section-card.soon { pointer-events: none; opacity: 0.5; }

  .feature { margin-bottom: clamp(3rem, 9vw, 6rem); }
  .feature-link {
    position: relative;
    display: block;
    min-height: clamp(340px, 55vh, 560px);
    border-radius: var(--radius);
    overflow: hidden;
    isolation: isolate;
    color: #fff;
  }
  .feature-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-image: var(--cover);
    background-size: cover;
    background-position: center;
    transition: transform 1.2s var(--ease);
  }
  .feature-link::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(to top, rgba(0,0,0,0.7), rgba(0,0,0,0.1) 60%, transparent);
  }
  .feature-link:hover .feature-bg { transform: scale(1.04); }
  .feature-text {
    position: absolute;
    bottom: 0;
    padding: clamp(1.5rem, 4vw, 3rem);
    max-width: 60ch;
  }
  .feature-text .eyebrow { color: rgba(255,255,255,0.75); }
  .feature-text h2 { color: #fff; }
  .feature-text p { color: rgba(255,255,255,0.85); }
  .cta {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--accent);
  }
  .feature-text .cta { color: #fff; border-bottom: 1px solid rgba(255,255,255,0.6); padding-bottom: 2px; }

  .latest { margin-bottom: clamp(2rem, 6vw, 4rem); }
  .latest-link { display: block; }
  .latest-link h3 { margin-top: 0.4rem; transition: color 0.3s var(--ease); }
  .latest-link:hover h3 { color: var(--accent); }
  .latest-link p { color: var(--muted); }
</style>
