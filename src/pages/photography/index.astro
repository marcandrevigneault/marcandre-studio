---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const published = (c: { data: { draft: boolean } }) => import.meta.env.DEV || !c.data.draft;
const galleries = (await getCollection('galleries', published)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Photography" description="Photo galleries — each with its own mood, motion, and sound.">
  <header class="intro wrap">
    <p class="eyebrow" data-reveal>Photography</p>
    <h1 data-reveal="1">Galleries</h1>
    <p class="lede measure" data-reveal="2">
      Each gallery is a place of its own — its own colour, typography, motion and, sometimes,
      a sound to sit inside while you look.
    </p>
  </header>

  <ul class="gallery-list wrap">
    {galleries.map((g, i) => (
      <li data-reveal={String(i % 4)}>
        <a href={`/photography/${g.id}/`} style={`--cover:url('${g.data.cover}'); --accent:${g.data.theme.accent ?? 'var(--accent)'}`}>
          <div class="thumb"><div class="thumb-bg"></div></div>
          <div class="meta">
            <h2>{g.data.title}</h2>
            <p class="place">{g.data.place}{g.data.place && ' · '}{g.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</p>
            <p class="summary">{g.data.summary}</p>
          </div>
        </a>
      </li>
    ))}
  </ul>

  {galleries.length === 0 && (
    <p class="measure empty">No galleries yet — add a markdown file in <code>src/content/galleries/</code>.</p>
  )}
</BaseLayout>

<style>
  .intro { padding-block: clamp(3rem, 10vw, 6rem) clamp(2rem, 5vw, 3rem); }
  .lede { color: var(--muted); font-size: clamp(1.05rem, 1rem + 0.4vw, 1.3rem); }

  .gallery-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr));
    gap: clamp(1.5rem, 4vw, 3rem);
  }
  .gallery-list a { display: block; }
  .thumb {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius);
    background: color-mix(in oklab, var(--ink) 6%, transparent);
  }
  .thumb-bg {
    width: 100%;
    height: 100%;
    background-image: var(--cover);
    background-size: cover;
    background-position: center;
    transition: transform 1.1s var(--ease), filter 0.6s var(--ease);
    filter: saturate(0.92);
  }
  .gallery-list a:hover .thumb-bg { transform: scale(1.05); filter: saturate(1.05); }
  .meta { padding-top: 1rem; }
  .meta h2 { font-size: 1.5rem; margin-bottom: 0.2rem; transition: color 0.3s var(--ease); }
  .gallery-list a:hover h2 { color: var(--accent); }
  .place {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.5rem;
  }
  .summary { color: var(--muted); margin: 0; }
  .empty { padding-block: 3rem; color: var(--muted); }
</style>
